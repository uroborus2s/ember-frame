  "cues": [
    {
      "id": "d001",
      "type": "voiceover",
      "shot_id": "SC001-SH001",
      "time_window": "00:00.0-00:03.5",
      "speaker_id": "VO_NARRATOR",
      "speaker": "旁白",
      "text": "肃明历1226年，北境十三部落联盟大举入寇。",
      "delivery": "中低音冷静历史旁白，压住战场，不煽情；读完整句后留出撞门和骨钟声。",
      "placement": "full_shot",
      "export_file": "audio/dialogue/d001.wav"
    },
    {
      "id": "d002",
      "type": "voiceover",
      "shot_id": "SC001-SH002",
      "time_window": "00:03.5-00:05.3",
      "speaker_id": "VO_NARRATOR",
      "speaker": "旁白",
      "text": "北关五百载，白骨未成尘。",
      "delivery": "镜头末尾落下，字短、重、冷；最后三个字不要拖腔。",
      "placement": "shot_end",
      "export_file": "audio/dialogue/d002.wav"
    },
    {
      "id": "d003",
      "type": "dialogue",
      "shot_id": "SC001-SH003",
      "time_window": "00:05.3-00:07.2",
      "speaker_id": "XUE_LINQIANG",
      "speaker": "薛临墙",
      "text": "敌人上来了。",
      "delivery": "低声、急促但不慌，像把墙头视线拉回门线；压过风声但不喊。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d003.wav"
    },
    {
      "id": "d004",
      "type": "dialogue",
      "shot_id": "SC002-SH003",
      "time_window": "00:20.2-00:27.2",
      "speaker_id": "GRAIN_TAX_CLERK",
      "speaker": "粮税小吏",
      "text": "查清明籍。金河不清，粮也得清；族谱对不上，粮就不算你家的。",
      "delivery": "干薄平直，像念账册；不要怒吼，恐怖来自制度确定性。",
      "placement": "front_to_mid",
      "export_file": "audio/dialogue/d004.wav"
    },
    {
      "id": "d005",
      "type": "dialogue",
      "shot_id": "SC002-SH003",
      "time_window": "00:20.2-00:27.2",
      "speaker_id": "GRAIN_WOMAN",
      "speaker": "妇人",
      "text": "这是过冬粮。",
      "delivery": "短促、发紧、护家，不哭喊；句尾被粮袋拖走声压住。",
      "placement": "shot_end",
      "export_file": "audio/dialogue/d005.wav"
    },
    {
      "id": "d006",
      "type": "voiceover",
      "shot_id": "SC002-SH004",
      "time_window": "00:27.2-00:35.2",
      "speaker_id": "VO_NARRATOR",
      "speaker": "旁白",
      "text": "官笔一点，良户成逃籍；粮归官仓，人归押车，祖牌还在，家门没了。",
      "delivery": "压低、稳，像宣读结果；不要替妇人哭，车轮和粮袋声逐渐盖住尾句。",
      "placement": "full_shot",
      "export_file": "audio/dialogue/d006.wav"
    },
    {
      "id": "d007",
      "type": "dialogue",
      "shot_id": "SC003-SH002",
      "time_window": "00:42.2-00:50.2",
      "speaker_id": "GU_HUAIZHANG",
      "speaker": "顾怀章",
      "text": "你不是逃。你是日月还在人间的证据。",
      "delivery": "年长旧臣，中慢，温度不高；像把使命压到晏南枝身上。",
      "placement": "front",
      "export_file": "audio/dialogue/d007.wav"
    },
    {
      "id": "d008",
      "type": "dialogue",
      "shot_id": "SC003-SH002",
      "time_window": "00:42.2-00:50.2",
      "speaker_id": "YAN_NANZHI",
      "speaker": "晏南枝",
      "text": "证据能让北边的人开门吗？",
      "delivery": "清冷、克制，先停半拍再问；尊严下面有疲惫。",
      "placement": "back_half",
      "export_file": "audio/dialogue/d008.wav"
    },
    {
      "id": "d009",
      "type": "dialogue",
      "shot_id": "SC003-SH003",
      "time_window": "00:50.2-00:59.2",
      "speaker_id": "GU_HUAIZHANG",
      "speaker": "顾怀章",
      "text": "找到月下盟书。旧臣看见它，就会记起该跪向谁。",
      "delivery": "更低、更重，旧帝国忠诚里带排除性；雨声不能盖字。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d009.wav"
    },
    {
      "id": "d010",
      "type": "voiceover",
      "shot_id": "SC003-SH004",
      "time_window": "00:59.2-01:08.2",
      "speaker_id": "VO_NARRATOR",
      "speaker": "旁白",
      "text": "南方遗民仍在旧歌里找路，却不知道路尽头等着的，不一定是皇座。",
      "delivery": "从南方雨夜转残阳坳前落下，冷静反转，不嘲讽。",
      "placement": "full_shot",
      "export_file": "audio/dialogue/d010.wav"
    },
    {
      "id": "d011",
      "type": "subtitle_only",
      "shot_id": "SC004-SH001",
      "time_window": "01:08.2-01:17.2",
      "speaker_id": "TITLE_CARD",
      "speaker": "字幕",
      "text": "肃明历1226年，残阳坳。",
      "delivery": "不配音，只做后期字幕。",
      "placement": "shot_start",
      "export_file": ""
    },
    {
      "id": "d012",
      "type": "dialogue",
      "shot_id": "SC004-SH002",
      "time_window": "01:17.2-01:25.2",
      "speaker_id": "BAICE_CLERK",
      "speaker": "白册官吏",
      "text": "残阳坳，原旧驿地名一处。按清明籍，逐户复核。",
      "delivery": "细硬、洁净、重复感强；像白册开页，不带怒气。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d011.wav"
    },
    {
      "id": "d013",
      "type": "dialogue",
      "shot_id": "SC004-SH004",
      "time_window": "01:33.2-01:40.2",
      "speaker_id": "SHEN_ZHAOMIAN",
      "speaker": "沈照眠",
      "text": "红花不落雪留灯。",
      "delivery": "童声轻快地背出，尾音忽然意识到不对后断掉。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d012.wav"
    },
    {
      "id": "d014",
      "type": "dialogue",
      "shot_id": "SC004-SH005",
      "time_window": "01:40.2-01:49.2",
      "speaker_id": "LUO_QINGHE",
      "speaker": "罗青禾",
      "text": "孩子背药名，背串了。",
      "delivery": "马上挡住，压低但稳，像把危险往自己身上接。",
      "placement": "front_half",
      "export_file": "audio/dialogue/d013.wav"
    },
    {
      "id": "d015",
      "type": "dialogue",
      "shot_id": "SC004-SH005",
      "time_window": "01:40.2-01:49.2",
      "speaker_id": "BAICE_CLERK",
      "speaker": "白册官吏",
      "text": "红花是药。留灯是哪味药？",
      "delivery": "平直追问，语速不快；像抓住册面错行。",
      "placement": "back_half",
      "export_file": "audio/dialogue/d014.wav"
    },
    {
      "id": "d016",
      "type": "dialogue",
      "shot_id": "SC004-SH006",
      "time_window": "01:49.2-01:59.2",
      "speaker_id": "SHEN_WEISANG",
      "speaker": "沈维桑",
      "text": "那是后山旧药路，我让她背来认草。官爷要验旧话，就验我这张猎户嘴。",
      "delivery": "半真半假，少年猎户硬撑轻松；弓弦被按住的细响和轻咳重叠。",
      "placement": "full_shot",
      "export_file": "audio/dialogue/d015.wav"
    },
    {
      "id": "d017",
      "type": "dialogue",
      "shot_id": "SC004-SH007",
      "time_window": "01:59.2-02:06.2",
      "speaker_id": "BAICE_CLERK",
      "speaker": "白册官吏",
      "text": "沈家。祖上这一笔说不清，先挂疑名。",
      "delivery": "近、干、轻，像把一家人写进格子。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d016.wav"
    },
    {
      "id": "d018",
      "type": "dialogue",
      "shot_id": "SC004-SH008",
      "time_window": "02:06.2-02:15.2",
      "speaker_id": "BAICE_CLERK",
      "speaker": "白册官吏",
      "text": "香烧完还说不清，全家按疑户押册。",
      "delivery": "制度性宣告，句尾不要加情绪；清明香插木裂声清楚。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d017.wav"
    },
    {
      "id": "d019",
      "type": "dialogue",
      "shot_id": "SC005-SH002",
      "time_window": "02:36.2-02:45.2",
      "speaker_id": "LUO_QINGHE",
      "speaker": "罗青禾",
      "text": "别动。柜板一响，白册就能把药屋写成窝户。",
      "delivery": "极低、稳，先制止再说明后果；药剪和门外甲片摩擦在下层。",
      "placement": "front_half",
      "export_file": "audio/dialogue/d018.wav"
    },
    {
      "id": "d020",
      "type": "dialogue",
      "shot_id": "SC005-SH003",
      "time_window": "02:45.2-02:55.2",
      "speaker_id": "YAN_NANZHI",
      "speaker": "晏南枝",
      "text": "你知道我是谁？",
      "delivery": "压低，仍有旧礼法尊严；不是求救。",
      "placement": "front_half",
      "export_file": "audio/dialogue/d019.wav"
    },
    {
      "id": "d021",
      "type": "dialogue",
      "shot_id": "SC005-SH003",
      "time_window": "02:45.2-02:55.2",
      "speaker_id": "LUO_QINGHE",
      "speaker": "罗青禾",
      "text": "知道你会害死这里的人。",
      "delivery": "冷静、直接，不恨她；像医生判断伤势。",
      "placement": "back_half",
      "export_file": "audio/dialogue/d020.wav"
    },
    {
      "id": "d022",
      "type": "dialogue",
      "shot_id": "SC005-SH004",
      "time_window": "02:55.2-03:04.2",
      "speaker_id": "YAN_NANZHI",
      "speaker": "晏南枝",
      "text": "这是昭明驿记。",
      "delivery": "低声确认，短促但字清；带一瞬旧物被认出的震动。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d021.wav"
    },
    {
      "id": "d023",
      "type": "dialogue",
      "shot_id": "SC005-SH005",
      "time_window": "03:04.2-03:15.2",
      "speaker_id": "LUO_QINGHE",
      "speaker": "罗青禾",
      "text": "旗一露，残阳坳就不是村，是反寨；白册一写，良户也成逆户。",
      "delivery": "压低但更硬，句子要一口气压完，门外敲门声切断尾音。",
      "placement": "front_to_mid",
      "export_file": "audio/dialogue/d022.wav"
    },
    {
      "id": "d024",
      "type": "dialogue",
      "shot_id": "SC005-SH005",
      "time_window": "03:04.2-03:15.2",
      "speaker_id": "GATE_SLAVE_SOLDIER",
      "speaker": "封门奴兵",
      "text": "开药柜。",
      "delivery": "门外，僵硬、麻木、短命令；带木门隔音。",
      "placement": "shot_end",
      "export_file": "audio/dialogue/d023.wav"
    },
    {
      "id": "d025",
      "type": "dialogue",
      "shot_id": "SC006-SH002",
      "time_window": "03:23.2-03:31.2",
      "speaker_id": "BAICE_CLERK",
      "speaker": "白册官吏",
      "text": "查出旧驿暗号，按窝户论。先封全村户口，谁家都不许改供。",
      "delivery": "程序性宣告，声音近而冷；人群惊气在后面。",
      "placement": "full_shot",
      "export_file": "audio/dialogue/d024.wav"
    },
    {
      "id": "d026",
      "type": "dialogue",
      "shot_id": "SC006-SH004",
      "time_window": "03:39.2-03:46.2",
      "speaker_id": "BAICE_CLERK",
      "speaker": "白册官吏",
      "text": "沈照眠，听旧歌有反应。先记作疑童。",
      "delivery": "蜡笔落纸声大于人声，句子像诊断标签。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d025.wav"
    },
    {
      "id": "d027",
      "type": "dialogue",
      "shot_id": "SC006-SH006",
      "time_window": "03:55.2-04:04.2",
      "speaker_id": "BAI_YI",
      "speaker": "白翳",
      "text": "一块暗号藏不住这么多年。有人开过门，也有人带过路。",
      "delivery": "高阶清明院声线，冷、稳、洁净；像在擦拭虫蜡针后下判断。",
      "placement": "full_shot",
      "export_file": "audio/dialogue/d026.wav"
    },
    {
      "id": "d028",
      "type": "dialogue",
      "shot_id": "SC006-SH007",
      "time_window": "04:04.2-04:11.2",
      "speaker_id": "BAI_YI",
      "speaker": "白翳",
      "text": "残阳坳按逆案查办。封村，清户，搜旧井。",
      "delivery": "慢、洁净、不可商量；每个动词像盖一个印。",
      "placement": "mid_shot",
      "export_file": "audio/dialogue/d027.wav"
    },
    {
      "id": "d029",
      "type": "dialogue",
      "shot_id": "SC006-SH009",
      "time_window": "04:19.2-04:28.2",
      "speaker_id": "BAI_YI",
      "speaker": "白翳",
      "text": "大人能改供，孩子改不了童谣。祖上留的暗号，歌一接，根脚就露了。",
      "delivery": "低冷，不急；不要反派笑，白册翻页声像骨钟回声。",
      "placement": "full_shot",
      "export_file": "audio/dialogue/d028.wav"
    }
  ]
}
