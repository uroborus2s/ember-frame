{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WriterRoomAgentResult",
  "type": "object",
  "required": ["status", "summary", "artifacts", "next_actions", "warnings", "handoff"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "warning", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "content"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "enum": ["markdown", "json", "text"]},
          "content": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "next_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "handoff": {
      "type": "object",
      "required": ["main_output", "assumptions", "quality_notes", "blocked_questions"],
      "properties": {
        "main_output": {"type": "string"},
        "assumptions": {"type": "array", "items": {"type": "string"}},
        "quality_notes": {"type": "array", "items": {"type": "string"}},
        "blocked_questions": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
