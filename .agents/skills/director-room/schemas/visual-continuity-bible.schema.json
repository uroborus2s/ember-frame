{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Director Room Visual Continuity Bible",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "characters", "locations", "props", "continuity_rules"],
  "properties": {
    "version": {
      "type": "string"
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["continuity_id", "name", "appearance", "wardrobe"],
        "properties": {
          "continuity_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "appearance": {
            "type": "string"
          },
          "wardrobe": {
            "type": "string"
          }
        }
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["continuity_id", "name", "spatial_layout"],
        "properties": {
          "continuity_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "spatial_layout": {
            "type": "string"
          },
          "scene_control_package_id": {
            "type": "string"
          }
        }
      }
    },
    "props": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["continuity_id", "name", "description"],
        "properties": {
          "continuity_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "continuity_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scene_control_packages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "package_id",
          "scene_id",
          "layout_source",
          "required_control_outputs",
          "status"
        ],
        "properties": {
          "package_id": {
            "type": "string"
          },
          "scene_id": {
            "type": "string"
          },
          "scene_bible_path": {
            "type": "string"
          },
          "layout_source": {
            "type": "string",
            "enum": ["layout_yaml", "blender", "unreal", "manual", "missing"]
          },
          "master_reference_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blockout_plan_path": {
            "type": "string"
          },
          "required_control_outputs": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "top_view",
                "camera_map",
                "shot_guide",
                "depth",
                "lineart",
                "mask",
                "openpose",
                "first_frame",
                "last_frame"
              ]
            }
          },
          "status": {
            "type": "string",
            "enum": ["ready", "planned", "needs_config", "missing_asset", "blocked"]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
