{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Director Room Shot QC Report",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "shots"],
  "properties": {
    "version": {"type": "string"},
    "shots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["shot_id", "status", "findings", "owner_fix"],
        "properties": {
          "shot_id": {"type": "string"},
          "status": {
            "type": "string",
            "enum": [
              "accepted",
              "needs_redraw",
              "needs_regenerate",
              "needs_prompt_tuning",
              "needs_asset_fix",
              "needs_script_fix",
              "needs_audio_fix",
              "blocked"
            ]
          },
          "findings": {"type": "array", "items": {"type": "string"}},
          "owner_fix": {"type": "string", "enum": ["director-room", "art-room", "writer-room", "none"]}
        }
      }
    }
  }
}
