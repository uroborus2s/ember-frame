{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Director Room Scene Image Resource Index",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "resources"],
  "properties": {
    "version": {
      "type": "string"
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "resource_id",
          "scene_id",
          "resource_type",
          "target_path",
          "status",
          "usage",
          "continuity_locks",
          "source_refs"
        ],
        "properties": {
          "resource_id": {
            "type": "string"
          },
          "scene_id": {
            "type": "string"
          },
          "resource_type": {
            "type": "string",
            "enum": [
              "master_reference_front",
              "master_reference_reverse",
              "key_prop_placement",
              "blocking_overview",
              "shot_scene_image",
              "director_reference_image",
              "shot_reference",
              "control_export"
            ]
          },
          "target_path": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["ready", "planned", "needs_generation", "needs_config", "blocked"]
          },
          "usage": {
            "type": "string"
          },
          "continuity_locks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
