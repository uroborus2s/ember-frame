{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Art Room Thread Plan",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "batches"],
  "properties": {
    "version": {
      "type": "string"
    },
    "batches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "batch_id",
          "batch_type",
          "creation_order",
          "depends_on_batches",
          "depends_on_assets",
          "prompt_ids",
          "output_paths",
          "output_format_contracts",
          "thread_prompt"
        ],
        "properties": {
          "batch_id": {
            "type": "string",
            "minLength": 1
          },
          "batch_type": {
            "type": "string",
            "enum": ["characters", "locations", "props-costumes", "style", "reference-frames"]
          },
          "creation_order": {
            "type": "integer",
            "minimum": 1
          },
          "depends_on_batches": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "depends_on_assets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prompt_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "output_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(assets/|[0-9]{2}/assets/)",
              "allOf": [
                {
                  "not": {
                    "pattern": "(^|/)(v[0-9]+|versions?|drafts?)(/|$)"
                  }
                },
                {
                  "not": {
                    "pattern": "(^|/)history/"
                  }
                },
                {
                  "not": {
                    "pattern": "\\.v[0-9]{3}\\.[^/]+$"
                  }
                }
              ]
            }
          },
          "output_format_contracts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "asset_id",
                "asset_type",
                "asset_subtype",
                "prompt_id",
                "output_path",
                "output_format"
              ],
              "properties": {
                "asset_id": {
                  "type": "string"
                },
                "asset_type": {
                  "type": "string",
                  "enum": ["character", "location", "prop", "costume", "style", "reference_frame"]
                },
                "asset_subtype": {
                  "type": "string",
                  "enum": [
                    "character_master_card",
                    "character_episode_state_card",
                    "prop_master_card",
                    "prop_episode_state_card",
                    "location_master_scene_card",
                    "location_episode_scene_card",
                    "style_reference",
                    "reference_frame",
                    "shot_override"
                  ]
                },
                "prompt_id": {
                  "type": "string"
                },
                "output_path": {
                  "type": "string",
                  "pattern": "^(assets/|[0-9]{2}/assets/)",
                  "allOf": [
                    {
                      "not": {
                        "pattern": "(^|/)(v[0-9]+|versions?|drafts?)(/|$)"
                      }
                    },
                    {
                      "not": {
                        "pattern": "(^|/)history/"
                      }
                    },
                    {
                      "not": {
                        "pattern": "\\.v[0-9]{3}\\.[^/]+$"
                      }
                    }
                  ]
                },
                "output_format": {
                  "$ref": "#/$defs/output_format"
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "asset_type": {"const": "character"},
                      "asset_subtype": {"const": "character_master_card"}
                    },
                    "required": ["asset_type", "asset_subtype"]
                  },
                  "then": {"properties": {"output_path": {"pattern": "^assets/characters/"}}}
                },
                {
                  "if": {
                    "properties": {
                      "asset_type": {"const": "character"},
                      "asset_subtype": {"const": "character_episode_state_card"}
                    },
                    "required": ["asset_type", "asset_subtype"]
                  },
                  "then": {
                    "properties": {"output_path": {"pattern": "^[0-9]{2}/assets/characters/"}}
                  }
                },
                {
                  "if": {
                    "properties": {
                      "asset_type": {"const": "location"},
                      "asset_subtype": {"const": "location_master_scene_card"}
                    },
                    "required": ["asset_type", "asset_subtype"]
                  },
                  "then": {"properties": {"output_path": {"pattern": "^assets/locations/"}}}
                },
                {
                  "if": {
                    "properties": {
                      "asset_type": {"const": "location"},
                      "asset_subtype": {"const": "location_episode_scene_card"}
                    },
                    "required": ["asset_type", "asset_subtype"]
                  },
                  "then": {
                    "properties": {"output_path": {"pattern": "^[0-9]{2}/assets/locations/"}}
                  }
                },
                {
                  "if": {
                    "properties": {
                      "asset_type": {"const": "prop"},
                      "asset_subtype": {"const": "prop_master_card"}
                    },
                    "required": ["asset_type", "asset_subtype"]
                  },
                  "then": {"properties": {"output_path": {"pattern": "^assets/props/"}}}
                },
                {
                  "if": {
                    "properties": {
                      "asset_type": {"const": "prop"},
                      "asset_subtype": {"const": "prop_episode_state_card"}
                    },
                    "required": ["asset_type", "asset_subtype"]
                  },
                  "then": {"properties": {"output_path": {"pattern": "^[0-9]{2}/assets/props/"}}}
                },
                {
                  "if": {
                    "properties": {
                      "asset_type": {"const": "costume"},
                      "asset_subtype": {"const": "prop_master_card"}
                    },
                    "required": ["asset_type", "asset_subtype"]
                  },
                  "then": {"properties": {"output_path": {"pattern": "^assets/costumes/"}}}
                },
                {
                  "if": {
                    "properties": {
                      "asset_type": {"const": "costume"},
                      "asset_subtype": {"const": "prop_episode_state_card"}
                    },
                    "required": ["asset_type", "asset_subtype"]
                  },
                  "then": {
                    "properties": {"output_path": {"pattern": "^[0-9]{2}/assets/costumes/"}}
                  }
                },
                {
                  "if": {
                    "properties": {"asset_subtype": {"const": "style_reference"}},
                    "required": ["asset_subtype"]
                  },
                  "then": {"properties": {"output_path": {"pattern": "^assets/style/"}}}
                },
                {
                  "if": {
                    "properties": {"asset_subtype": {"const": "reference_frame"}},
                    "required": ["asset_subtype"]
                  },
                  "then": {
                    "properties": {
                      "output_path": {"pattern": "^[0-9]{2}/assets/reference-frames/"}
                    }
                  }
                },
                {
                  "if": {
                    "properties": {"asset_subtype": {"const": "shot_override"}},
                    "required": ["asset_subtype"]
                  },
                  "then": {
                    "properties": {
                      "output_path": {"pattern": "^[0-9]{2}/assets/shot-overrides/"}
                    }
                  }
                }
              ]
            }
          },
          "thread_prompt": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "output_format": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "deliverable_kind",
        "file_format",
        "minimum_resolution",
        "background_policy",
        "alpha_policy",
        "canvas_aspect_ratio",
        "required_views",
        "composition_layers",
        "qc_checks"
      ],
      "properties": {
        "deliverable_kind": {
          "type": "string",
          "enum": [
            "neutral_master_card",
            "episode_state_card",
            "transparent_cutout",
            "turnaround_sheet",
            "detail_crop_sheet",
            "location_scene_card",
            "style_reference",
            "video_reference_frame",
            "shot_override_frame",
            "precision_overlay"
          ]
        },
        "file_format": {"type": "string", "enum": ["png", "jpg", "svg"]},
        "minimum_resolution": {
          "type": "string",
          "pattern": "^([0-9]+x[0-9]+|project_defined)$"
        },
        "background_policy": {
          "type": "string",
          "enum": ["neutral_plain", "transparent_alpha", "scene_context", "video_frame"]
        },
        "alpha_policy": {"type": "string", "enum": ["required", "forbidden", "optional"]},
        "canvas_aspect_ratio": {
          "type": "string",
          "enum": ["1:1", "4:5", "16:9", "project_defined"]
        },
        "required_views": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "composition_layers": {
          "type": "object",
          "additionalProperties": true,
          "required": ["foreground", "midground", "background"],
          "properties": {
            "foreground": {"type": "string"},
            "midground": {"type": "string"},
            "background": {"type": "string"}
          }
        },
        "qc_checks": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      }
    }
  }
}
