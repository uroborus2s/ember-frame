{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Art Room Prop Costume Designs",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "props"],
  "properties": {
    "version": {"type": "string"},
    "props": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "asset_id",
          "file",
          "asset_type",
          "asset_subtype",
          "display_name",
          "prop_lock",
          "physical_dimensions",
          "episode_state",
          "card_layout",
          "output_format_requirements",
          "continuity_refs",
          "source_refs",
          "usage"
        ],
        "properties": {
          "asset_id": {"type": "string"},
          "file": {"type": "string", "pattern": "^[^/]{1,20}\\.[^./]+$"},
          "asset_type": {"type": "string", "enum": ["prop", "costume"]},
          "asset_subtype": {
            "type": "string",
            "enum": ["prop_master_card", "prop_episode_state_card"]
          },
          "display_name": {"type": "string"},
          "prop_lock": {"type": "object", "additionalProperties": true},
          "physical_dimensions": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "length",
              "width",
              "height",
              "scale_reference",
              "weight_feel",
              "material_thickness"
            ],
            "properties": {
              "length": {"type": "string"},
              "width": {"type": "string"},
              "height": {"type": "string"},
              "scale_reference": {"type": "string"},
              "weight_feel": {"type": "string"},
              "material_thickness": {"type": "string"}
            }
          },
          "episode_state": {"type": "object", "additionalProperties": true},
          "card_layout": {"type": "array", "items": {"type": "string"}},
          "output_format_requirements": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "master_card_background",
              "cutout_background",
              "required_views",
              "detail_crops",
              "scale_reference_required"
            ],
            "properties": {
              "master_card_background": {"type": "string", "const": "neutral_plain"},
              "cutout_background": {"type": "string", "const": "transparent_alpha"},
              "required_views": {
                "type": "array",
                "minItems": 3,
                "items": {"type": "string"}
              },
              "detail_crops": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string"}
              },
              "scale_reference_required": {"type": "boolean", "const": true}
            }
          },
          "continuity_refs": {"type": "array", "items": {"type": "string"}},
          "source_refs": {"type": "array", "items": {"type": "string"}},
          "usage": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
