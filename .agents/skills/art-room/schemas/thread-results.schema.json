{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Art Room Thread Results",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "status", "threads", "blocked_jobs"],
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "warning", "blocked"]
    },
    "threads": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["batch_id", "thread_id", "status", "created_files", "warnings"],
        "properties": {
          "batch_id": {
            "type": "string"
          },
          "thread_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["completed", "warning", "blocked"]
          },
          "created_files": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(assets/|[0-9]{2}/assets/)",
              "allOf": [
                {
                  "not": {
                    "pattern": "(^|/)(v[0-9]+|versions?|drafts?)(/|$)"
                  }
                },
                {
                  "not": {
                    "pattern": "(^|/)history/"
                  }
                },
                {
                  "not": {
                    "pattern": "\\.v[0-9]{3}\\.[^/]+$"
                  }
                }
              ]
            }
          },
          "history_files": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(assets/|[0-9]{2}/assets/)",
              "allOf": [
                {
                  "pattern": "(^|/)history/"
                },
                {
                  "pattern": "\\.v[0-9]{3}\\.[^/]+$"
                },
                {
                  "not": {
                    "pattern": "(^|/)(v[0-9]+|versions?|drafts?)(/|$)"
                  }
                }
              ]
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "blocked_jobs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
