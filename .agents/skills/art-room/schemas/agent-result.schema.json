{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Art Room Agent Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "artifacts", "next_actions", "warnings", "handoff"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "warning", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "content"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["markdown", "json"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["main_output", "assumptions", "quality_notes", "blocked_questions"],
      "properties": {
        "main_output": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quality_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
