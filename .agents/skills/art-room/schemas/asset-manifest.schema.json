{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Art Room Asset Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "assets"],
  "properties": {
    "version": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "asset_id",
          "asset_type",
          "asset_subtype",
          "file",
          "display_name",
          "output_path",
          "creation_order",
          "creation_phase",
          "depends_on_assets",
          "blocks_assets",
          "dependency_reason",
          "priority",
          "output_format",
          "source_refs",
          "continuity_refs",
          "usage"
        ],
        "properties": {
          "asset_id": {
            "type": "string",
            "minLength": 1
          },
          "asset_type": {
            "type": "string",
            "enum": ["character", "location", "prop", "costume", "style", "reference_frame"]
          },
          "asset_subtype": {
            "type": "string",
            "enum": [
              "character_master_card",
              "character_episode_state_card",
              "prop_master_card",
              "prop_episode_state_card",
              "location_master_scene_card",
              "location_episode_scene_card",
              "style_reference",
              "reference_frame",
              "shot_override"
            ]
          },
          "file": {
            "type": "string",
            "pattern": "^[^/]{1,20}\\.[^./]+$"
          },
          "display_name": {
            "type": "string"
          },
          "output_path": {
            "type": "string",
            "pattern": "^(assets/|[0-9]{2}/assets/)",
            "allOf": [
              {
                "not": {
                  "pattern": "(^|/)(v[0-9]+|versions?|drafts?)(/|$)"
                }
              },
              {
                "not": {
                  "pattern": "(^|/)history/"
                }
              },
              {
                "not": {
                  "pattern": "\\.v[0-9]{3}\\.[^/]+$"
                }
              }
            ]
          },
          "creation_order": {
            "type": "integer",
            "minimum": 1
          },
          "creation_phase": {
            "type": "string",
            "enum": [
              "style_reference",
              "master_cards",
              "episode_state_cards",
              "precision_assets",
              "reference_frames",
              "shot_overrides"
            ]
          },
          "depends_on_assets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocks_assets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependency_reason": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "output_format": {
            "$ref": "#/$defs/output_format"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "continuity_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "usage": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "asset_type": {"const": "character"},
                "asset_subtype": {"const": "character_master_card"}
              },
              "required": ["asset_type", "asset_subtype"]
            },
            "then": {"properties": {"output_path": {"pattern": "^assets/characters/"}}}
          },
          {
            "if": {
              "properties": {
                "asset_type": {"const": "character"},
                "asset_subtype": {"const": "character_episode_state_card"}
              },
              "required": ["asset_type", "asset_subtype"]
            },
            "then": {
              "properties": {"output_path": {"pattern": "^[0-9]{2}/assets/characters/"}}
            }
          },
          {
            "if": {
              "properties": {
                "asset_type": {"const": "location"},
                "asset_subtype": {"const": "location_master_scene_card"}
              },
              "required": ["asset_type", "asset_subtype"]
            },
            "then": {"properties": {"output_path": {"pattern": "^assets/locations/"}}}
          },
          {
            "if": {
              "properties": {
                "asset_type": {"const": "location"},
                "asset_subtype": {"const": "location_episode_scene_card"}
              },
              "required": ["asset_type", "asset_subtype"]
            },
            "then": {
              "properties": {"output_path": {"pattern": "^[0-9]{2}/assets/locations/"}}
            }
          },
          {
            "if": {
              "properties": {
                "asset_type": {"const": "prop"},
                "asset_subtype": {"const": "prop_master_card"}
              },
              "required": ["asset_type", "asset_subtype"]
            },
            "then": {"properties": {"output_path": {"pattern": "^assets/props/"}}}
          },
          {
            "if": {
              "properties": {
                "asset_type": {"const": "prop"},
                "asset_subtype": {"const": "prop_episode_state_card"}
              },
              "required": ["asset_type", "asset_subtype"]
            },
            "then": {"properties": {"output_path": {"pattern": "^[0-9]{2}/assets/props/"}}}
          },
          {
            "if": {
              "properties": {
                "asset_type": {"const": "costume"},
                "asset_subtype": {"const": "prop_master_card"}
              },
              "required": ["asset_type", "asset_subtype"]
            },
            "then": {"properties": {"output_path": {"pattern": "^assets/costumes/"}}}
          },
          {
            "if": {
              "properties": {
                "asset_type": {"const": "costume"},
                "asset_subtype": {"const": "prop_episode_state_card"}
              },
              "required": ["asset_type", "asset_subtype"]
            },
            "then": {
              "properties": {"output_path": {"pattern": "^[0-9]{2}/assets/costumes/"}}
            }
          },
          {
            "if": {
              "properties": {"asset_subtype": {"const": "style_reference"}},
              "required": ["asset_subtype"]
            },
            "then": {"properties": {"output_path": {"pattern": "^assets/style/"}}}
          },
          {
            "if": {
              "properties": {"asset_subtype": {"const": "reference_frame"}},
              "required": ["asset_subtype"]
            },
            "then": {
              "properties": {"output_path": {"pattern": "^[0-9]{2}/assets/reference-frames/"}}
            }
          },
          {
            "if": {
              "properties": {"asset_subtype": {"const": "shot_override"}},
              "required": ["asset_subtype"]
            },
            "then": {
              "properties": {"output_path": {"pattern": "^[0-9]{2}/assets/shot-overrides/"}}
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "output_format": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "deliverable_kind",
        "file_format",
        "minimum_resolution",
        "background_policy",
        "alpha_policy",
        "canvas_aspect_ratio",
        "required_views",
        "composition_layers",
        "qc_checks"
      ],
      "properties": {
        "deliverable_kind": {
          "type": "string",
          "enum": [
            "neutral_master_card",
            "episode_state_card",
            "transparent_cutout",
            "turnaround_sheet",
            "detail_crop_sheet",
            "location_scene_card",
            "style_reference",
            "video_reference_frame",
            "shot_override_frame",
            "precision_overlay"
          ]
        },
        "file_format": {
          "type": "string",
          "enum": ["png", "jpg", "svg"]
        },
        "minimum_resolution": {
          "type": "string",
          "pattern": "^([0-9]+x[0-9]+|project_defined)$"
        },
        "background_policy": {
          "type": "string",
          "enum": ["neutral_plain", "transparent_alpha", "scene_context", "video_frame"]
        },
        "alpha_policy": {
          "type": "string",
          "enum": ["required", "forbidden", "optional"]
        },
        "canvas_aspect_ratio": {
          "type": "string",
          "enum": ["1:1", "4:5", "16:9", "project_defined"]
        },
        "required_views": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "composition_layers": {
          "type": "object",
          "additionalProperties": true,
          "required": ["foreground", "midground", "background"],
          "properties": {
            "foreground": {
              "type": "string"
            },
            "midground": {
              "type": "string"
            },
            "background": {
              "type": "string"
            }
          }
        },
        "qc_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
