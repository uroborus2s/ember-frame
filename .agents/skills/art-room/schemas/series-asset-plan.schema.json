{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Art Room Series Asset Plan",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "master_assets"],
  "properties": {
    "version": {"type": "string"},
    "master_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["asset_id", "asset_subtype", "planned_file", "reason"],
        "properties": {
          "asset_id": {"type": "string"},
          "asset_subtype": {
            "type": "string",
            "enum": ["character_master_card", "prop_master_card", "location_master_scene_card", "style_reference"]
          },
          "planned_file": {"type": "string", "pattern": "^[^/]{1,20}\\.[^./]+$"},
          "reason": {"type": "string"}
        }
      }
    }
  }
}
